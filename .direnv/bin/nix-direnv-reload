#!/usr/bin/env bash
set -e
if [[ ! -d "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science/.envrc" "/home/pedro0210/Documents/Uvg/FourthYear/Data-Science/Project_01_Data_Science/.direnv"/*.rc
